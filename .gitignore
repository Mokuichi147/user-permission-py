# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Claude Code が生成する worktree
.claude/worktrees/

# SQLite runtime files
*.db
*.db-shm
*.db-wal
*.key

# Rust build artefacts
/target/
**/*.rs.bk

# maturin develop / uv sync で生成される native extension (in-tree)
python/user_permission/*.so
python/user_permission/*.pyd

# uv が pyproject.toml から再生成するロックファイル (依存ゼロのため固定不要)
uv.lock
